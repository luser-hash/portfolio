SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-backend-service.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-backend-service.onrender.com,https://your-frontend-domain.vercel.app
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
SERVE_MEDIA_FILES=True
# Leave CLOUDINARY_URL empty to use local backend/media storage.
# On Render Free, set CLOUDINARY_URL instead of using local disk for uploads.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_MEDIA_FOLDER=portfolio
MEDIA_ROOT=media
MEDIA_URL=/media/
